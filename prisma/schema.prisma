generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Alunos {
  id        Int      @id @default(autoincrement())
  name      String
  idade     Int
  cpf       Int      @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cursos    Cursos[] @relation("AlunosToCursos")
}

model Cursos {
  id           Int      @id @default(autoincrement())
  nome         String
  professor    String?
  cargaHoraria Int
  descricao    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  alunos       Alunos[] @relation("AlunosToCursos")
}

model Funcionarios {
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String
  admin Boolean @default(false)
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt
}